      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600&display=swap');\n</style>\n\n<div class=\"font-[Inter,sans-serif] bg-[#f5f0ea]\" data-kid=\"1\">\n\n  \n  <div class=\"bg-[#edeae4] border-b border-[#ddd8d0] py-[10px] px-5 flex items-center justify-center relative\" data-kid=\"2\">\n    <span class=\"text-[11px] tracking-[0.18em] uppercase text-[#3b3731] font-medium\" data-kid=\"3\">\n      Free US Shipping on Orders Over $45\n    </span>\n    <button class=\"absolute right-5 w-7 h-7 flex items-center justify-center text-[#3b3731] hover:opacity-50 transition-opacity\" aria-label=\"Pause\" data-kid=\"4\">\n      <svg width=\"11\" height=\"11\" viewBox=\"0 0 11 11\" fill=\"currentColor\" data-kid=\"5\">\n        <rect x=\"1\" y=\"0\" width=\"3.5\" height=\"11\" rx=\"0.5\" data-kid=\"6\"></rect>\n        <rect x=\"6.5\" y=\"0\" width=\"3.5\" height=\"11\" rx=\"0.5\" data-kid=\"7\"></rect>\n      </svg>\n    </button>\n  </div>\n\n  \n  <nav class=\"relative bg-[#f5f0ea] border-b border-[#ddd8d0] px-10 py-[18px] flex items-center justify-between\" data-kid=\"8\">\n    \n    <div class=\"flex items-center gap-9\" data-kid=\"9\">\n      <a href=\"#\" class=\"text-[11.5px] tracking-[0.14em] uppercase text-[#3b3731] font-medium hover:opacity-50 transition-opacity\" data-kid=\"10\">Shop</a>\n      <a href=\"#\" class=\"text-[11.5px] tracking-[0.14em] uppercase text-[#3b3731] font-medium hover:opacity-50 transition-opacity\" data-kid=\"11\">About</a>\n      <a href=\"#\" class=\"text-[11.5px] tracking-[0.14em] uppercase text-[#3b3731] font-medium hover:opacity-50 transition-opacity\" data-kid=\"12\">Futures</a>\n    </div>\n\n    \n    <a href=\"#\" class=\"absolute left-1/2 -translate-x-1/2 text-[30px] font-[300] tracking-[-0.01em] text-[#3b3731] lowercase hover:opacity-50 transition-opacity select-none\" data-kid=\"13\">\n      rhode\n    </a>\n\n    \n    <div class=\"flex items-center g