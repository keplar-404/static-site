      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap');\n</style>\n\n<div class=\"bg-white font-[Inter,sans-serif] relative py-6 px-10\" data-kid=\"1\">\n\n  \n  <button class=\"absolute left-3 z-20 w-9 h-9 rounded-full border border-[#c8c3bc] bg-white flex items-center justify-center hover:bg-[#f0ede8] transition-colors duration-200 shadow-xs\" style=\"top: 288px\" aria-label=\"Previous\" data-kid=\"2\">\n    <svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\" stroke=\"#3b3731\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"3\">\n      <path d=\"M9 2L4 7L9 12\" data-kid=\"4\"></path>\n    </svg>\n  </button>\n\n  \n  <div class=\"flex gap-3\" data-kid=\"5\">\n\n    \n    <div class=\"group relative flex-1 rounded-2xl bg-[#efece8] overflow-hidden cursor-pointer\" style=\"height:560px\" data-kid=\"6\">\n\n      \n      <div class=\"absolute inset-x-4 top-4 z-20 flex items-start justify-between pointer-events-none\" data-kid=\"7\">\n        <span class=\"font-bold text-[44px] leading-none text-[#2e2b29] group-hover:text-white transition-colors duration-300\" style=\"font-family:'Space Grotesk',sans-serif\" data-kid=\"8\">shape</span>\n        <span class=\"rounded-full px-3 py-[5px] text-[9px] font-semibold tracking-[0.1em] uppercase mt-1.5\n                 bg-[#2e2b29] text-white group-hover:bg-white/90 group-hover:text-[#2e2b29] transition-colors duration-300\" data-kid=\"9\">first access</span>\n      </div>\n\n      \n      <div class=\"absolute inset-0 flex flex-col opacity-100 group-hover:opacity-0 transition-opacity duration-300 pointer-events-none\" data-kid=\"10\">\n        <div class=\"flex-1 flex items-center justify-center pt-20 px-16\" data-kid=\"11\">\n          <img src=\"https://images.unsplash.com/photo-1497278727017-4f2d90e16b3e?auto=format&w=400&q=80&fit=crop\" alt=\"Pepti